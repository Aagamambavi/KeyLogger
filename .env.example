# KeyLogger Environment Configuration
# Copy this file to .env and fill in your actual values

# === Gmail Configuration (Required for Email Reports) ===
# Get app password from: https://myaccount.google.com/apppasswords
# Steps:
# 1. Enable 2-Step Verification on Gmail account
# 2. Go to App passwords (requires 2FA enabled)
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the 16-character password below
EMAIL_PASSWORD=your_16_character_app_password

# === MongoDB Configuration (Optional) ===
# Default: localhost:27017
# For MongoDB Atlas cloud, use your connection string

# MongoDB Server Host
MONGODB_HOST=localhost

# MongoDB Server Port
MONGODB_PORT=27017

# Optional: MongoDB Username (if authentication enabled)
# MONGODB_USERNAME=your_username

# Optional: MongoDB Password (if authentication enabled)
# MONGODB_PASSWORD=your_password

# === Application Settings ===
# Session timeout in seconds (default: 300 = 5 minutes)
MAX_IDLE_TIME=300
